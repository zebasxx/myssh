# PostgreSQL Database Configuration
POSTGRES_PASSWORD=changeme_secure_password_here

# Microsoft Entra ID (Azure AD) Configuration
# Register your app at https://portal.azure.com -> Entra ID -> App registrations
ENTRA_CLIENT_ID=your-client-id-here
ENTRA_CLIENT_SECRET=your-client-secret-here
ENTRA_TENANT_ID=your-tenant-id-here
ENTRA_REDIRECT_URI=https://myssh.argostranslations.com/auth/callback

# Session Management
# Generate with: openssl rand -hex 32
SESSION_SECRET=generate-a-random-secret-at-least-32-characters-long

# Application Configuration
BASE_URL=https://myssh.argostranslations.com
NODE_ENV=production
